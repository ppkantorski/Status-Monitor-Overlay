[status-monitor]
battery_avg_iir_filter=false
battery_time_left_refreshrate=60
average_gpu_load=false
use_old_fps_average=false

[full]
refresh_rate=2
sample_rate=2
layer_width_align=left
show_real_freqs=true
show_deltas=true
show_target_freqs=true
show_fps=true
show_res=true
show_read_speed=true
use_dynamic_colors=true
disable_screenshots=false
separator_color=#2DFF
cat_color_1=#8FFF
cat_color_2=#8CFF
text_color=#FFFF
background_color=#0009
focus_background_color=#000F

[mini]
refresh_rate=30
sample_rate=2
handheld_font_size=15
docked_font_size=15
docked_1080p_font_size=21
use_1080p_docked=true
spacing=15
horizontal_padding=36
vertical_padding=36
corner_radius=36
stacked_spacing=4
real_freqs=true
real_volts=true
show_full_cpu=true
show_full_cpu_max_core_012=true
show_stacked_full_cpu=true
show_full_res=true
show_primary_res=false
show_soc_voltage=true
show_stacked_fan_soc=true
