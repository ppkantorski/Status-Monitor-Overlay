use_dtc_symbol=true
dtc_format_1=%a, %b %d
dtc_format_2=%l:%M:%S %p
integer_fps=false
use_fps_graph=true
show=DTC+BAT+CPU+GPU+RAM+TMP+RES+FPS
element_order=DTC+BAT+CPU+GPU+RAM+MEM+SOC+TMP+READ+RES+FPS
show_labels=true
replace_MB_with_RAM_load=true
show_RAM_load_CPU_GPU=false
show_stacked_ram_load_cpu_gpu=true
